# Copy to .env and fill in. NEVER commit real secrets.
PORT=4000
# self-hosted Postgres
DATABASE_URL=postgres://ceos:ceos@localhost:5432/ceos
# sign JWTs — generate a long random value in production
JWT_SECRET=change-me-to-a-long-random-string
# allowed browser origin (the Vite dev server)
CORS_ORIGIN=http://localhost:5173
