{
  "name": "ce-os-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "migrate": "node --import tsx/esm scripts/migrate.ts",
    "migrate:status": "node --import tsx/esm scripts/migrate.ts --status",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1",
    "puppeteer": "^25.1.0",
    "tsx": "^4.22.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
